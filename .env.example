# ===== DATABASE (Supabase) =====
# Obter em: https://app.supabase.com/project/YOUR_PROJECT/settings/database
DATABASE_URL=postgresql://postgres:your_supabase_password@db.xxxxx.supabase.co:5432/postgres

# Supabase específico
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# ===== AUTHENTICATION =====
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ===== ENVIRONMENT =====
MIX_ENV=dev

# ===== SERVER =====
PHX_PORT=4000
PHX_HOST=localhost

# ===== JOB QUEUE (Oban) =====
# Local: redis://localhost:6379
# Se usar apenas PostgreSQL (sem Redis), comentar essa linha
# Oban guardará jobs diretamente no banco
# OBAN_QUEUES_REDIS_URL=redis://localhost:6379

# ===== OPTIONAL INTEGRATIONS =====
# AWS S3 (para upload de arquivos)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# Sentry (error tracking)
# SENTRY_DSN=

# Webhook Test Service
# WEBHOOK_TEST_URL=https://webhook.site/unique-id
